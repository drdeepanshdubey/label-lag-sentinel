# ---- OpenRouter (required for the LLM causality narrative) ----
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# Fallback model used automatically if the primary errors
OPENROUTER_FALLBACK_MODEL=google/gemini-flash-1.5
# Optional metadata sent to OpenRouter (analytics / routing)
OPENROUTER_APP_URL=https://github.com/your-handle/label-lag-sentinel
OPENROUTER_APP_NAME=Label Lag Sentinel

# ---- openFDA (optional) ----
# Without a key: 240 req/min. With a key: 1000 req/min. https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
